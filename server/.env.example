# ─────────────────────────────────────────────────────────────────────────────
# Cadence backend — environment template.
#
# Copy to `.env` and fill in real values. `.env` is git-ignored; this file is not.
# .NET does NOT read .env automatically — export it first:
#     set -a && source .env && set +a
# Values containing ';' or spaces MUST stay quoted, or they truncate when sourced.
#
# '__' is the configuration nesting separator (blueprint §11.1).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
ConnectionStrings__Postgres="Host=localhost;Port=5432;Database=cadence;Username=cadence;Password=change-me"
# Apply EF migrations at startup. Convenient locally; NEVER true in production (§8.4).
Database__MigrateOnStartup=true
# Seconds before a command is cancelled.
Database__CommandTimeoutSeconds=30
# Retries for transient faults (connection resets, failovers) by the EF execution strategy.
Database__MaxRetryCount=3
# Logs parameter values and full SQL. Development only — transcripts are customer content.
Database__EnableSensitiveDataLogging=false
# Read by the design-time factory for `dotnet ef database update`. Scaffolding a migration opens
# no connection, so this only matters when applying one locally.
CADENCE_MIGRATIONS_CONNECTION="Host=localhost;Port=5432;Database=cadence;Username=cadence;Password=change-me"

# ── Redis (optional) ────────────────────────────────────────────────────────
# Omit to fall back to an in-memory cache — single instance only (§13).
Redis__ConnectionString="localhost:6379"

# ── JWT ─────────────────────────────────────────────────────────────────────
# MUST be at least 32 bytes. Generate: openssl rand -base64 48
Jwt__SigningKey="replace-with-a-long-random-secret-at-least-32-bytes"
Jwt__Issuer="https://cadence.local"
Jwt__Audience="cadence-api"
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# ── Google OAuth (the only sign-in method, §4) ──────────────────────────────
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web).
# Must match the client's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
Google__ClientId="000000000000-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"

# ── Cloudinary (file storage, §12) ──────────────────────────────────────────
# Leave empty to run without file storage: the document endpoints then fail with a
# configuration error instead of the process refusing to boot. Nothing is ever recorded
# as stored when it was not.
Cloudinary__Url="cloudinary://api_key:api_secret@cloud_name"
# First folder segment under `cadence/`, so staging and production can share one cloud
# account without writing into each other's tenants (§12.2).
Cloudinary__Environment="development"

# ── AI provider (summaries + chat, §23.3) ───────────────────────────────────
# Leave Ai__ApiKey empty to run without AI: summaries then record summary_status=failed,
# which is the same terminal state a real outage produces. Nothing is ever fabricated.
Ai__Provider="anthropic"          # only "anthropic" is implemented today
Ai__ApiKey=""
Ai__Model="claude-opus-4-8"
Ai__Effort="high"                 # low | medium | high | xhigh | max
Ai__MaxTokens=8000
Ai__TimeoutSeconds=120
# Cost ceiling: transcripts longer than this are truncated, and the model is told they were.
Ai__MaxTranscriptCharacters=200000

# ── Background jobs (Hangfire, §14) ─────────────────────────────────────────
# Set false to enqueue without executing — used by the test host so a worker cannot
# race the assertions.
Jobs__RunWorker=true

# ── Speech-to-text (§23.4) ──────────────────────────────────────────────────
Transcription__Provider="deepgram"
Transcription__ApiKey="replace-me"

# ── CORS (§15) ──────────────────────────────────────────────────────────────
# One indexed entry per allowed origin. Never use a wildcard with credentials.
Cors__AllowedOrigins__0="http://localhost:3000"

# ── Hosting ─────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5290
