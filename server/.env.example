# ─────────────────────────────────────────────────────────────────────────────
# Cadence backend — environment template.
#
# Copy to `.env` and fill in real values. `.env` is git-ignored; this file is not.
# .NET does NOT read .env automatically — export it first:
#     set -a && source .env && set +a
# Values containing ';' or spaces MUST stay quoted, or they truncate when sourced.
#
# '__' is the configuration nesting separator (blueprint §11.1).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
ConnectionStrings__Postgres="Host=localhost;Port=5432;Database=cadence;Username=cadence;Password=change-me"
# Apply EF migrations at startup. Convenient locally; NEVER true in production (§8.4).
Database__MigrateOnStartup=true

# ── Redis (optional) ────────────────────────────────────────────────────────
# Omit to fall back to an in-memory cache — single instance only (§13).
Redis__ConnectionString="localhost:6379"

# ── JWT ─────────────────────────────────────────────────────────────────────
# MUST be at least 32 bytes. Generate: openssl rand -base64 48
Jwt__SigningKey="replace-with-a-long-random-secret-at-least-32-bytes"
Jwt__Issuer="https://cadence.local"
Jwt__Audience="cadence-api"
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# ── Google OAuth (the only sign-in method, §4) ──────────────────────────────
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web).
# Must match the client's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
Google__ClientId="000000000000-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"

# ── Cloudinary (file storage, §12) ──────────────────────────────────────────
# File endpoints fail loudly until this is set.
Cloudinary__Url="cloudinary://api_key:api_secret@cloud_name"

# ── AI provider (summaries + chat, §23.3) ───────────────────────────────────
Ai__Provider="anthropic"          # anthropic | openai | gemini
Ai__ApiKey="replace-me"
Ai__Model="claude-sonnet-5"
Ai__TimeoutSeconds=60

# ── Speech-to-text (§23.4) ──────────────────────────────────────────────────
Transcription__Provider="deepgram"
Transcription__ApiKey="replace-me"

# ── CORS (§15) ──────────────────────────────────────────────────────────────
# One indexed entry per allowed origin. Never use a wildcard with credentials.
Cors__AllowedOrigins__0="http://localhost:3000"

# ── Hosting ─────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5290
